# GitHub Channels — Configuration
# Copy to .env and fill in values

# Comma-separated list of repos to accept webhooks from
# Example: vantasnerdan/agent-model-pipeline,finml-sage/archon,mlops-kelvin/kelvin-agent
GITHUB_REPOS=

# Webhook secret (shared with GitHub webhook config)
# Generate: openssl rand -hex 20
GITHUB_WEBHOOK_SECRET=

# Port for the HTTP webhook listener
PORT=8789

# Comma-separated event types to forward (empty = all)
# Options: push,pull_request,issues,issue_comment,pull_request_review,check_run,workflow_run,release
GITHUB_EVENTS=push,pull_request,issues,issue_comment,pull_request_review

# Muted at startup? (true/false)
MUTED=false

# Comma-separated GitHub usernames of trusted actors (principals + team)
# Events from these actors get trust_tier=team in metadata
# Events from anyone else get trust_tier=external
TRUSTED_ACTORS=vantasnerdan,mlops-kelvin,finml-sage,nexus-marbell,bohdan-marbell

# Custom tip appended to every channel event (optional)
# Use this to remind agents about mute commands or team conventions
CHANNEL_TIP=Tip: curl -X POST localhost:8789/mute/owner/repo?hours=5 to mute an active repo.
