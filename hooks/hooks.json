{
  "description": "github-channels plugin — auto-setup on session start",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/setup.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
